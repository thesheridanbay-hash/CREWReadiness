{
  "name": "crewreadiness",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered employee training and onboarding for landscaping companies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thesheridanbay-hash/CREWReadiness.git"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check --ignore-path .gitignore .",
    "format:fix": "prettier --write --ignore-path .gitignore .",
    "typecheck": "tsc --noEmit",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx ./scripts/seed-dev.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "evals": "tsx ./evals/run.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.57.0",
    "@vercel/blob": "^2.4.0",
    "better-auth": "^1.6.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "inngest": "^4.5.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-circular-progressbar": "^2.2.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.6",
    "react-markdown": "^9.1.0",
    "react-use": "^17.6.1",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "pg": "^8.21.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4.1.8"
  }
}
