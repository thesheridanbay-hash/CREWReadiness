# .env

# disabled next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# neon db uri — APP RUNTIME role (app_runtime: non-owner, FORCE RLS applies; see db/rls.sql)
DATABASE_URL="postgresql://app_runtime:<password>@<host>:<port>/crewreadiness?sslmode=require"

# neon db uri — OWNER role (migrations + db/rls.sql + seeds only; never the app)
DATABASE_URL_OWNER="postgresql://<owner>:<password>@<host>:<port>/crewreadiness?sslmode=require"

# public app url (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
